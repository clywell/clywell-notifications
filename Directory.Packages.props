<Project>
    <PropertyGroup>
        <ManagePackageVersionsCentrally>true</ManagePackageVersionsCentrally>
    </PropertyGroup>

    <ItemGroup>
        <!-- DI Abstractions -->
        <PackageVersion Include="Microsoft.Extensions.DependencyInjection.Abstractions"
            Version="10.0.6" />
        <PackageVersion Include="Microsoft.Extensions.DependencyInjection" Version="10.0.6" />

        <!-- Logging Abstractions -->
        <PackageVersion Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.6" />

        <!-- SMTP Provider -->
        <PackageVersion Include="MailKit" Version="4.16.0" />
        <PackageVersion Include="MimeKit" Version="4.16.0" />

        <!-- Template Rendering -->
        <PackageVersion Include="Scriban" Version="7.1.0" />

        <!-- Test Framework -->
        <PackageVersion Include="xunit" Version="2.9.3" />
        <PackageVersion Include="xunit.runner.visualstudio" Version="3.1.5" />
        <PackageVersion Include="Microsoft.NET.Test.Sdk" Version="18.4.0" />

        <!-- Mocking -->
        <PackageVersion Include="Moq" Version="4.20.72" />

        <!-- Code Coverage -->
        <PackageVersion Include="coverlet.collector" Version="10.0.0" />

        <!-- Versioning -->
        <PackageVersion Include="Nerdbank.GitVersioning" Version="3.9.50" />

        <!-- Source Link -->
        <PackageVersion Include="Microsoft.SourceLink.GitHub" Version="10.0.202" />

        <!-- Realtime (Wave 2) -->
        <PackageVersion Include="Microsoft.AspNetCore.SignalR.Core" Version="1.2.9" />

        <!-- Security patch for transitive dependency from SignalR.Core -->
        <PackageVersion Include="Newtonsoft.Json" Version="13.0.4" />

        <!-- Providers -->
        <PackageVersion Include="FirebaseAdmin" Version="3.1.0" />
    </ItemGroup>
</Project>